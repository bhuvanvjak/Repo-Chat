{
  "manifest_version": 3,
  "name": "GitReader",
  "version": "0.2.0",
  "description": "Chat with any git repository, right from your browser. Local embeddings + Groq-powered chat, with streaming answers.",
  "permissions": ["sidePanel", "storage"],
  "host_permissions": ["https://github.com/*", "http://localhost/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open GitReader"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
